# ==========================================
# CarCheck backend — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# ==========================================

# --- Banco de dados (MariaDB) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=carcheck
# Tamanho do pool de conexões. SEM default no código (parseInt -> NaN se ausente),
# portanto defina explicitamente. Recomendado: 10.
DB_CONNECTION_LIMIT=10
# M8: tempo máx. (ms) que uma request espera por conexão livre do pool antes de
# falhar rápido (ER_GET_CONNECTION_TIMEOUT -> 503). Default 10000 se ausente.
DB_ACQUIRE_TIMEOUT=10000
# M7: janela (ms) de cache do resultado do /health. Sob flood, o pool é tocado no
# máx. 1x por janela em vez de 1x por request (anti-DoS). Default 5000 se ausente.
HEALTH_CACHE_MS=5000

# --- Autenticação (JWT) ---
# JWT_SECRET must be at least 32 characters and must NOT be a default/placeholder value.
# The server refuses to start otherwise (see startup check in index.js).
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate_with__node_-e_"console.log(require('crypto').randomBytes(48).toString('hex'))"
# Validade do token. Default no código: 12h. Aceita formatos do jsonwebtoken (ex.: 2h, 7d).
# Também dirige o maxAge do cookie de sessão (M4). Reduzido para 2h (janela de exposição).
JWT_EXPIRES_IN=2h

# --- Cookie de sessão (M4) ---
# O token JWT é gravado em cookie httpOnly (fora do alcance de XSS).
# COOKIE_SECURE controla a flag Secure do cookie. Mantenha "false" na LAN (HTTP);
# defina "true" ao publicar via HTTPS (Cloudflare). NÃO é dirigido por NODE_ENV:
# o servidor LAN roda HTTP com NODE_ENV=production, então amarrar ao NODE_ENV
# impediria o cookie de trafegar.
COOKIE_SECURE=false
# COOKIE_DOMAIN (opcional): domínio do cookie ao publicar (ex.: .seudominio.com).
# Deixe vazio na LAN — o cookie fica restrito ao host atual.
COOKIE_DOMAIN=

# --- Servidor ---
PORT=3000
# Interface de bind. Default no código: 0.0.0.0 (todas as interfaces).
HOST=0.0.0.0
# Controla a EXPOSIÇÃO DE DETALHES DE ERRO ao cliente:
#   production  -> erros 500 inesperados retornam mensagem genérica; sem stack/err.message
#   qualquer outro valor (ou ausente) -> retorna err.message e stack (apenas para dev)
# Defina como "production" em produção.
NODE_ENV=production
# Nível de log (A14): error < warn < info < debug. Abaixo do limiar, a chamada é no-op.
# Os logs com PII (matrícula/KM) são `debug` → SILENCIOSOS em produção por padrão (LGPD).
# Default no código: 'info' quando NODE_ENV=production, senão 'debug'. Valor inválido cai
# no default do ambiente. Suba para 'debug' só temporariamente para diagnóstico.
LOG_LEVEL=info

# --- CORS ---
# Origens adicionais permitidas, separadas por vírgula (sem espaços obrigatórios).
# O host LAN http://10.10.1.100:10081 já é permitido por padrão no código.
# Ao publicar via Cloudflare, adicione o domínio público aqui, ex.:
#   CORS_ORIGINS=https://carcheck.seudominio.com,https://www.carcheck.seudominio.com
CORS_ORIGINS=
