# ==========================================
# CarCheck backend — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# ==========================================

# --- Banco de dados (MariaDB) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=carcheck
# Tamanho do pool de conexões. SEM default no código (parseInt -> NaN se ausente),
# portanto defina explicitamente. Recomendado: 10.
DB_CONNECTION_LIMIT=10

# --- Autenticação (JWT) ---
# JWT_SECRET must be at least 32 characters and must NOT be a default/placeholder value.
# The server refuses to start otherwise (see startup check in index.js).
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate_with__node_-e_"console.log(require('crypto').randomBytes(48).toString('hex'))"
# Validade do token. Default no código: 12h. Aceita formatos do jsonwebtoken (ex.: 12h, 7d).
JWT_EXPIRES_IN=12h

# --- Servidor ---
PORT=3000
# Interface de bind. Default no código: 0.0.0.0 (todas as interfaces).
HOST=0.0.0.0
# Controla a EXPOSIÇÃO DE DETALHES DE ERRO ao cliente:
#   production  -> erros 500 inesperados retornam mensagem genérica; sem stack/err.message
#   qualquer outro valor (ou ausente) -> retorna err.message e stack (apenas para dev)
# Defina como "production" em produção.
NODE_ENV=production

# --- CORS ---
# Origens adicionais permitidas, separadas por vírgula (sem espaços obrigatórios).
# O host LAN http://10.10.1.100:10081 já é permitido por padrão no código.
# Ao publicar via Cloudflare, adicione o domínio público aqui, ex.:
#   CORS_ORIGINS=https://carcheck.seudominio.com,https://www.carcheck.seudominio.com
CORS_ORIGINS=
